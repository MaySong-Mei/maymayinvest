# Copy to .env and fill in. Never commit .env.

# Database (matches v1/infra/docker-compose.yml)
DATABASE_URL=postgresql+psycopg://maymay:maymay_dev@localhost:5544/maymayinvest_v1
DATABASE_URL_ASYNC=postgresql+asyncpg://maymay:maymay_dev@localhost:5544/maymayinvest_v1

# Alpaca paper account — get at https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_FEED=iex  # free tier; switch to "sip" if you have the subscription

# Auth — dev only; replace before any non-laptop deploy
JWT_SECRET=dev-only-change-me
JWT_ALG=HS256

# Vault master key — encrypts broker_credentials rows. Set even in dev.
VAULT_MASTER_KEY=dev-only-32-byte-master-key-rotate

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json   # json | console

# Risk limits (global; per-capability decorators may tighten)
GLOBAL_MAX_ORDERS_PER_MIN=20
GLOBAL_MAX_NOTIONAL_PER_DAY=50000
