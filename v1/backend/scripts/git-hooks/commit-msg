#!/usr/bin/env python
"""commit-msg hook enforcing the Append-only operator invariant.

Git invokes this hook AFTER the commit message is written (whether
via -m or editor), passing the message file path as argv[1]. This
is the correct hook for message-aware checks; pre-commit runs before
the message exists.

See v1/docs/PHILOSOPHY.md "Append-only operator invariant" for the
six rules. This hook is the mechanical enforcement layer.

Install:
  cp v1/backend/scripts/git-hooks/commit-msg .git/hooks/commit-msg
  chmod +x .git/hooks/commit-msg

Behavior:
  - Reads the staged diff (git diff --cached).
  - Reads the commit message from sys.argv[1] (file path passed by git).
  - Detects modifications (vs adds-only) in the review-required surface.
  - Detects "lock/binding/recount/void/invalidate" keywords in message.
  - Detects touches to the binding artifact list itself.
  - Requires Reviewer-Id: <agent>:<diff-hash> trailer OR Non-Semantic
    trailer in the commit message.
  - Rejects with explanation if required trailer missing or hash mismatch.

Bypass: there is no clean bypass. To make a "wrong" commit the operator
must remove the hook, which is itself a binding-artifact modification
(scripts/git-hooks/commit-msg is in the review-required surface), and
that future commit would have to carry a Reviewer-Id. The hook is
removable, but removal is detectable in git history (commits land that
hook would have caught).
"""
from __future__ import annotations

import hashlib
import os
import re
import subprocess
import sys
from pathlib import Path


# Review-required surface. Initial list per PHILOSOPHY "Append-only
# operator invariant" Enforcement section. Add to this list via
# rule 6 (binding artifact list is itself binding).
#
# Path patterns are fnmatch-style. A modification (NOT a pure add)
# to a path matching any pattern triggers review-required.
REVIEW_REQUIRED_PATTERNS: list[str] = [
    "v1/docs/PHILOSOPHY.md",
    "v1/docs/V1_SCOPE.md",
    "v1/docs/ARCHITECTURE.md",
    "v1/docs/proposals/amendments/*.md",  # modification of filed amendments
    "v1/docs/evals/*-plan-*.md",  # pre-reg plans after lock
    "v1/docs/evals/analyzer-determinism-corpus/README.md",
    "v1/backend/app/intel/reviewer/prompt.py",
    "v1/backend/app/intel/analyzer/prompt.py",
    "v1/backend/scripts/git-hooks/commit-msg",  # the hook itself
]


# Keywords that suggest the commit performs a re-interpretation or
# binding action, even if the diff alone doesn't trip the surface check.
# This is the second-line defense against bundling.
KEYWORD_TRIGGERS: list[str] = [
    "lock pre-reg",
    "locking pre-reg",
    "void k=",
    "invalidate k=",
    "recount",
    "contamination",
    "contaminated",
    "deprecate",
    "deprecated",
    "reinterpret",
    "re-interpret",
    "binding artifact",
    "amend",
    "amendment",
]


# Trailer regex. Format:
#   Reviewer-Id: <agent-id>:<diff-hash>
#   Non-Semantic: <reason>
#   Mentioned-Governance-Keyword: <keyword>; reason: <>=20-char explanation>
REVIEWER_ID_RE = re.compile(
    r"^Reviewer-Id:\s*([A-Za-z0-9_-]+):([a-f0-9]{8,64})\s*$", re.MULTILINE
)
NON_SEMANTIC_RE = re.compile(r"^Non-Semantic:\s*\S+", re.MULTILINE)
MENTION_RE = re.compile(
    r"^Mentioned-Governance-Keyword:\s*([a-z0-9=\-, ]+?)\s*;\s*reason:\s*(.{20,})$",
    re.MULTILINE | re.IGNORECASE,
)


# Cadence threshold: every N consecutive Mentioned-Governance-Keyword
# declarations by the same operator (no review committed in between) triggers
# rule-5 cadence review. Counted by `git log --grep` so the source-of-truth
# is git history, not a mutable side-file. Per reviewer a0513e14879df99e1:
# "no new artifact, no new attack surface."
MENTION_CADENCE_LIMIT = 3


def _run(cmd: list[str]) -> str:
    """Run a git command, return stdout. Empty string on failure.
    Uses UTF-8 + errors='replace' so non-ASCII in diff (Chinese quotes
    in PHILOSOPHY, etc) doesn't crash the hook on Windows."""
    try:
        out_bytes = subprocess.check_output(cmd, stderr=subprocess.DEVNULL)
        return out_bytes.decode("utf-8", errors="replace")
    except (subprocess.CalledProcessError, FileNotFoundError):
        return ""


def _staged_diff() -> str:
    """Full staged diff content."""
    return _run(["git", "diff", "--cached", "--no-color"])


def _staged_files_status() -> list[tuple[str, str]]:
    """List of (status_letter, path) for staged files.

    Status letters: A=added, M=modified, D=deleted, R=renamed, etc.
    We care about distinguishing A (free append at the file level) from
    M (modification, potentially review-required).
    """
    out = _run(["git", "diff", "--cached", "--name-status"])
    pairs: list[tuple[str, str]] = []
    for line in out.splitlines():
        parts = line.split("\t")
        if len(parts) >= 2:
            status = parts[0][0]  # first letter (handles R### renames)
            path = parts[-1]
            pairs.append((status, path))
    return pairs


def _commit_message() -> str:
    """Read commit message. As a commit-msg hook, git passes the message
    file path as argv[1]. Fall back to .git/COMMIT_EDITMSG if no arg
    (e.g. when the hook is invoked manually for testing)."""
    if len(sys.argv) >= 2:
        msg_path = Path(sys.argv[1])
        if msg_path.exists():
            return msg_path.read_text(encoding="utf-8", errors="replace")
    # Fallback for manual invocation
    root = _run(["git", "rev-parse", "--show-toplevel"]).strip()
    if not root:
        return ""
    fallback = Path(root) / ".git" / "COMMIT_EDITMSG"
    if not fallback.exists():
        return ""
    return fallback.read_text(encoding="utf-8", errors="replace")


def _diff_hash(diff: str) -> str:
    """SHA-256 of the staged diff, hex-encoded, first 16 chars (sufficient
    uniqueness for our review-tracking purpose, short enough to type)."""
    return hashlib.sha256(diff.encode("utf-8")).hexdigest()[:16]


def _strip_quoted(msg: str) -> str:
    """Strip quoted/code-fenced/backtick-inline content from the message
    before keyword scanning. Per reviewer a0513e14879df99e1's design
    (C.2): keywords inside quoted blocks are descriptive references,
    not performative; they should not trigger the keyword check.

    Recognized quoting forms:
      - Lines starting with `>` (markdown blockquote)
      - Lines inside ```...``` fenced blocks
      - Inline `...` (backtick-wrapped)
      - Inline "..." (double-quoted)
    Bare prose still triggers — escape requires explicit quotation.
    """
    out: list[str] = []
    in_fence = False
    for line in msg.splitlines():
        if line.lstrip().startswith("```"):
            in_fence = not in_fence
            continue
        if in_fence:
            continue
        if line.lstrip().startswith(">"):
            continue
        # Strip inline `...` and "..." spans
        line = re.sub(r"`[^`]*`", "", line)
        line = re.sub(r'"[^"]*"', "", line)
        out.append(line)
    return "\n".join(out)


def _count_recent_mentions() -> int:
    """Count Mentioned-Governance-Keyword declarations in commit messages
    of recent commits (since the last Reviewer-Id-bearing commit). Used to
    enforce the cadence-review limit (C.1). Source is `git log --grep`,
    not a side-file, so the count cannot be silently mutated without
    rewriting history.

    Returns the count of mention-trailers in commits since the last commit
    bearing a Reviewer-Id trailer. The next commit with a Reviewer-Id
    resets the counter.
    """
    # Get recent commits' subjects + bodies; look for trailers.
    # Pretty format gives us full body for each commit, separated by \x00.
    raw = _run([
        "git", "log", "-30", "--format=%H%n%B%x00",  # 30-commit window is plenty
    ])
    if not raw:
        return 0
    commits = [c.strip() for c in raw.split("\x00") if c.strip()]
    count = 0
    for commit in commits:
        body = commit.split("\n", 1)[1] if "\n" in commit else ""
        # If we hit a Reviewer-Id-bearing commit, counter resets to 0
        if REVIEWER_ID_RE.search(body):
            return count
        if MENTION_RE.search(body):
            count += 1
    return count


def _matches_surface(path: str, patterns: list[str]) -> bool:
    """fnmatch-style check; * matches any chars in one path segment."""
    from fnmatch import fnmatch
    return any(fnmatch(path, p) for p in patterns)


def _is_modification(status: str) -> bool:
    """A=add (free), M=modify (review surface), R=rename (modify),
    D=delete (modify), C=copy (treat as modify)."""
    return status in {"M", "R", "D", "C"}


def main() -> int:
    diff = _staged_diff()
    files = _staged_files_status()
    msg = _commit_message()

    # Compute trigger reasons.
    triggers: list[str] = []

    # Trigger 1: modification (not pure add) on review-required surface.
    # Skipped when there's no staged diff (e.g. --allow-empty), since
    # there are no files to inspect.
    for status, path in files:
        if _is_modification(status) and _matches_surface(path, REVIEW_REQUIRED_PATTERNS):
            triggers.append(
                f"modifies review-required artifact: {path} (status={status})"
            )

    # Trigger 2: keyword in commit message suggesting re-interpret/binding
    # action. Runs UNCONDITIONALLY — including on empty commits. This
    # closes the empty-commit bypass: an empty `--allow-empty` commit
    # whose message contains a governance keyword (e.g. "amendment",
    # "recount", "binding artifact") is now caught here.
    # See PHILOSOPHY.md "Append-only operator invariant" — first
    # discovered when commit 1519537 (a corrigendum) bypassed via empty
    # diff. Reviewer a3441000d2edaf2f4 audited and recommended this fix.
    #
    # Strip quoted/code-fenced content first (C.2 per reviewer
    # a0513e14879df99e1): keywords inside `backticks`, "double-quotes",
    # > blockquotes, or ```fenced``` blocks are descriptive references,
    # not performative; they don't trigger. Bare prose still triggers.
    msg_unquoted = _strip_quoted(msg)
    msg_lower = msg_unquoted.lower()
    matched_keywords: list[str] = []
    for kw in KEYWORD_TRIGGERS:
        if kw in msg_lower:
            matched_keywords.append(kw)
            # Only the first match is surfaced in triggers messaging
            # (avoids redundant noise), but ALL matches are kept in
            # matched_keywords so the declaration-completeness check
            # below can verify every triggered keyword is named.
            # Removing the break here closes the multi-keyword bypass
            # reviewer aadf7e1baeeb097bb identified.
            if not matched_keywords[:-1]:  # first match only
                triggers.append(
                    f"commit message contains review-trigger keyword: {kw!r}"
                )

    # No triggers? Free append (or empty commit with no governance
    # keywords). Allow.
    if not triggers:
        return 0

    # Check for required trailer.
    rid_match = REVIEWER_ID_RE.search(msg)
    nonsem_match = NON_SEMANTIC_RE.search(msg)
    mention_match = MENTION_RE.search(msg)

    if rid_match:
        agent_id, claimed_hash = rid_match.group(1), rid_match.group(2)
        actual_hash = _diff_hash(diff)
        if not actual_hash.startswith(claimed_hash) and not claimed_hash.startswith(actual_hash):
            # Allow prefix match in either direction so operator can type
            # a shorter hash without exact match. But forbid clear mismatch.
            print(
                f"\nPRE-COMMIT REJECTED: Reviewer-Id hash mismatch.\n"
                f"  Claimed: {claimed_hash}\n"
                f"  Actual diff hash: {actual_hash}\n"
                f"  Reusing a reviewer's hash from a different diff is not allowed.\n"
                f"  See v1/docs/PHILOSOPHY.md 'Append-only operator invariant'.\n",
                file=sys.stderr,
            )
            return 1
        # Valid Reviewer-Id with matching hash. Allow.
        return 0

    if nonsem_match:
        # Non-semantic carve-out. Allow but warn that disagreement is a
        # rule-5 dispute.
        print(
            f"\nNon-Semantic trailer accepted. Note: if a reviewer post-hoc\n"
            f"disagrees, this constitutes a rule-5 dispute per PHILOSOPHY.md.\n",
            file=sys.stderr,
        )
        return 0

    if mention_match:
        # Mentioned-Governance-Keyword declaration (C per reviewer
        # a0513e14879df99e1). Operator declares the keyword was
        # mentioned in a descriptive (not performative) sense, with a
        # >=20-char reason.
        declared_raw = mention_match.group(1).strip().lower()
        reason = mention_match.group(2).strip()

        # Token-set semantics for declared keywords. Substring check would
        # let overlapping-keyword pairs bypass (e.g. declaring "amendment"
        # would silently cover "amend" because "amend" in "amendment").
        # Reviewer a8af941cce966d72f identified this in the C patch audit.
        # Format: comma-separated tokens; each declared token must be an
        # EXACT match to a triggered keyword in matched_keywords.
        declared_kws_set = {
            tok.strip() for tok in declared_raw.split(",") if tok.strip()
        }

        # The declared keyword(s) must include every triggering keyword.
        # Operator cannot declare "void k=" and silently mention "amendment".
        # Operator cannot declare "amendment" and silently mention "amend".
        missing = [kw for kw in matched_keywords if kw not in declared_kws_set]
        if missing:
            print(
                f"\nPRE-COMMIT REJECTED: Mentioned-Governance-Keyword "
                f"declaration is incomplete.\n"
                f"  Declared: {sorted(declared_kws_set)!r}\n"
                f"  Missing keyword(s) that triggered: {missing}\n"
                f"  All triggered keywords must be named in the declaration.\n",
                file=sys.stderr,
            )
            return 1

        # Cadence check (C.1): if too many recent mentions since the
        # last reviewed commit, force a Reviewer-Id.
        count = _count_recent_mentions()
        if count >= MENTION_CADENCE_LIMIT:
            print(
                f"\nPRE-COMMIT REJECTED: too many recent governance-keyword\n"
                f"declarations without intervening reviewer dispatch.\n"
                f"  Recent declarations since last Reviewer-Id: {count}\n"
                f"  Cadence limit: {MENTION_CADENCE_LIMIT}\n"
                f"  Dispatch a fresh-brain reviewer on this commit\n"
                f"  (or back-audit the recent declaration corpus) before\n"
                f"  continuing to ship declaration-trailer commits.\n",
                file=sys.stderr,
            )
            return 1

        print(
            f"\nMentioned-Governance-Keyword declaration accepted.\n"
            f"  Keyword(s): {sorted(declared_kws_set)}\n"
            f"  Reason: {reason[:80]}...\n"
            f"  Cadence count (since last Reviewer-Id): {count + 1}/"
            f"{MENTION_CADENCE_LIMIT}\n"
            f"  Note: declarations accumulate as rule-5-disputable\n"
            f"  artifacts; cadence review fires at the limit.\n",
            file=sys.stderr,
        )
        return 0

    # Triggered but no valid trailer. Reject.
    print(
        f"\nPRE-COMMIT REJECTED: append-only operator invariant violation.\n\n"
        f"Trigger reasons:\n",
        file=sys.stderr,
    )
    for t in triggers:
        print(f"  - {t}", file=sys.stderr)
    diff_h = _diff_hash(diff)
    print(
        f"\nThis commit requires fresh-brain review before landing.\n"
        f"\n"
        f"To proceed:\n"
        f"  1. Dispatch a dialogue reviewer on the staged diff.\n"
        f"     Reviewer should audit per rules 2/3/4/5/6 of the\n"
        f"     Append-only operator invariant (PHILOSOPHY.md).\n"
        f"  2. Capture the reviewer's agent id.\n"
        f"  3. Add a commit trailer:\n"
        f"     Reviewer-Id: <agent-id>:{diff_h}\n"
        f"\n"
        f"For non-semantic edits (typos, broken links, whitespace),\n"
        f"add a Non-Semantic: <reason> trailer instead.\n"
        f"\n"
        f"See v1/docs/PHILOSOPHY.md 'Append-only operator invariant' for\n"
        f"the full mandate.\n",
        file=sys.stderr,
    )
    return 1


if __name__ == "__main__":
    try:
        sys.exit(main())
    except Exception as exc:  # noqa: BLE001
        # Fail-closed: if the hook itself errors, reject rather than allow.
        # Operator must either fix the hook or use --no-verify (which is
        # itself an auditable action visible in git's reflog).
        print(
            f"\nPRE-COMMIT HOOK INTERNAL ERROR: {type(exc).__name__}: {exc}\n"
            f"Rejecting commit fail-closed. Either fix the hook or, in an\n"
            f"emergency, use `git commit --no-verify` and document why in\n"
            f"the next commit message.\n",
            file=sys.stderr,
        )
        sys.exit(1)
