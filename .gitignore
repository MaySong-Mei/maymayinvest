# Editor / tool state
# Ignore .claude contents but keep settings.local.json (it's project-shared
# permission config; see https://docs.claude.com/en/docs/claude-code/settings).
# Git won't traverse an ignored directory, so we ignore by glob instead of dir.
.claude/*
!.claude/settings.local.json
.idea/
.vscode/
*.swp
.DS_Store

# Python
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
dist/
*.egg-info/

# Env files (never commit secrets — see .env.example)
.env
*.env.local

# Node (for v1/frontend later)
node_modules/
.next/
